{
  "name": "hellebore-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "db:migrate": "sea-orm-cli migrate fresh -d src-tauri/migration",
    "db:fresh": "sqlite3 src-tauri/data/db.sqlite \"VACUUM;\" && pnpm run db:migrate",
    "build:entities": "pnpm run db:fresh && sea-orm-cli generate entity -l --with-serde both -o src-tauri/entity/src",
    "build:fe": "tsc && vite build",
    "build": "tauri build",
    "test:be": "cargo test --manifest-path ./src-tauri/Cargo.toml",
    "test:fe": "vitest run",
    "test": "pnpm run test:be && pnpm run test:fe",
    "preview": "vite preview",
    "dev:fe": "vite",
    "dev": "env-cmd tauri dev",
    "clippy:check": "cargo clippy --manifest-path src-tauri/Cargo.toml",
    "clippy:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --fix",
    "tsc:check": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "eslint:check": "eslint .",
    "eslint:fix": "eslint --fix .",
    "svelte-check": "svelte-check",
    "stylelint:check": "stylelint **/*.css",
    "stylelint:fix": "stylelint --fix **/*.css",
    "lint:check": "pnpm run eslint:check && pnpm run svelte-check && pnpm run stylelint:check",
    "lint:fix": "pnpm run eslint:fix && pnpm run svelte-check && pnpm run stylelint:fix",
    "rustfmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "rustfmt:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "prettier:check": "prettier --check \"**/*.{ts,svelte,css,md}\"",
    "prettier:fix": "prettier --write \"**/*.{ts,svelte,css,md}\"",
    "format:check": "pnpm run rustfmt:check && pnpm run prettier:check",
    "format:fix": "pnpm run rustfmt:fix && pnpm run prettier:fix",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.7.0",
    "@tauri-apps/plugin-dialog": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-mention": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "clsx": "^2.1.1",
    "prosemirror-model": "^1.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.*",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.7.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.7",
    "@typescript-eslint/parser": "^8.55.0",
    "bits-ui": "^2.16.3",
    "env-cmd": "^10.1.0",
    "eslint": "^9.*",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-import-resolver-vite": "^2.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-svelte": "^3.15.0",
    "espree": "^11.1.0",
    "global-jsdom": "^28.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "svelte": "^5.51.1",
    "svelte-check": "^4.4.0",
    "svelte-eslint-parser": "^1.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.rs": "rustfmt --edition 2024",
    "*.{ts,svelte}": "eslint --cache --fix",
    "*.css": "stylelint --fix",
    "*.{ts,svelte,css,md}": "prettier --write"
  }
}
