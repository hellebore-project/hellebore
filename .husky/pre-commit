pnpx lint-staged

# Run clippy on staged .rs files only if any exist
if git diff --cached --name-only | grep -q '\.rs$'; then
  pnpm run clippy:fix
  pnpm run clippy:check
fi

# Run tsc on staged .ts files only if any exist
if git diff --cached --name-only | grep -q '\.ts$'; then
    pnpm run tsc:check
fi
